<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_anomaly" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <collaboration id="Collab_anomaly">
    <participant id="part_anomaly" name="Anomaly Detection Flow" processRef="proc_anomaly" />
  </collaboration>
  <process id="proc_anomaly" isExecutable="false">
    <laneSet id="ls_anomaly">
      <lane id="lane_client" name="Client (Admin)">
        <flowNodeRef>ev_end</flowNodeRef>
        <flowNodeRef>t_request</flowNodeRef>
        <flowNodeRef>ev_start</flowNodeRef>
        <flowNodeRef>t_display</flowNodeRef>
      </lane>
      <lane id="lane_api" name="FastAPI — GET /ml/anomalies">
        <flowNodeRef>t_validate_token</flowNodeRef>
        <flowNodeRef>t_fetch_orders</flowNodeRef>
        <flowNodeRef>t_build_features</flowNodeRef>
        <flowNodeRef>t_call_detect</flowNodeRef>
        <flowNodeRef>t_flag_order</flowNodeRef>
        <flowNodeRef>t_skip</flowNodeRef>
        <flowNodeRef>t_build_response</flowNodeRef>
        <flowNodeRef>gw_is_anomaly</flowNodeRef>
        <flowNodeRef>gw_merge</flowNodeRef>
      </lane>
      <lane id="lane_ml" name="ML Service — IsolationForest">
        <flowNodeRef>t_load_model</flowNodeRef>
        <flowNodeRef>t_score_samples</flowNodeRef>
        <flowNodeRef>t_classify_severity</flowNodeRef>
      </lane>
      <lane id="lane_db" name="Database">
        <flowNodeRef>t_select_orders</flowNodeRef>
        <flowNodeRef>t_insert_anomaly</flowNodeRef>
      </lane>
    </laneSet>
    <task id="t_validate_token" name="Validate JWT Token&#10;get_current_user()" />
    <task id="t_fetch_orders" name="Fetch last N orders&#10;with features" />
    <task id="t_select_orders" name="SELECT orders&#10;ORDER BY order_date DESC&#10;LIMIT last_n" />
    <task id="t_build_features" name="Build Feature Matrix&#10;distance, weather, customs,&#10;total_value, estimated_days" />
    <task id="t_load_model" name="Load anomaly_model.pkl&#10;anomaly_scaler.pkl" />
    <task id="t_call_detect" name="Call detect_anomalies()&#10;MLService singleton" />
    <task id="t_score_samples" name="anomaly_scaler.transform()&#10;model.score_samples(X)" />
    <task id="t_classify_severity" name="Classify by score&#10;critical: score &#60; -0.3&#10;warning: score &#60; -0.1" />
    <task id="t_flag_order" name="Flag as ANOMALY&#10;set type, description, severity" />
    <task id="t_skip" name="Mark Normal&#10;skip" />
    <task id="t_insert_anomaly" name="INSERT INTO anomalies&#10;score, severity, description" />
    <task id="t_build_response" name="Build AnomalyOut list&#10;{ anomalies[], total_flagged }" />
    <endEvent id="ev_end" name="Detection Complete" />
    <sequenceFlow id="sf1" sourceRef="ev_start" targetRef="t_request" />
    <sequenceFlow id="sf2" sourceRef="t_request" targetRef="t_validate_token" />
    <sequenceFlow id="sf3" sourceRef="t_validate_token" targetRef="t_fetch_orders" />
    <sequenceFlow id="sf4" sourceRef="t_fetch_orders" targetRef="t_select_orders" />
    <sequenceFlow id="sf5" sourceRef="t_select_orders" targetRef="t_build_features" />
    <sequenceFlow id="sf6" sourceRef="t_build_features" targetRef="t_load_model" />
    <sequenceFlow id="sf7" sourceRef="t_load_model" targetRef="t_call_detect" />
    <sequenceFlow id="sf8" sourceRef="t_call_detect" targetRef="t_score_samples" />
    <sequenceFlow id="sf9" sourceRef="t_score_samples" targetRef="t_classify_severity" />
    <sequenceFlow id="sf10" sourceRef="t_classify_severity" targetRef="gw_is_anomaly" />
    <sequenceFlow id="sf11" name="Yes" sourceRef="gw_is_anomaly" targetRef="t_flag_order" />
    <sequenceFlow id="sf12" name="No" sourceRef="gw_is_anomaly" targetRef="t_skip" />
    <sequenceFlow id="sf13" sourceRef="t_flag_order" targetRef="t_insert_anomaly" />
    <sequenceFlow id="sf14" sourceRef="t_insert_anomaly" targetRef="gw_merge" />
    <sequenceFlow id="sf15" sourceRef="t_skip" targetRef="gw_merge" />
    <sequenceFlow id="sf16" sourceRef="gw_merge" targetRef="t_build_response" />
    <sequenceFlow id="sf17" sourceRef="t_build_response" targetRef="t_display" />
    <sequenceFlow id="sf18" sourceRef="t_display" targetRef="ev_end" />
    <task id="t_request" name="GET /ml/anomalies&#10;?last_n=200" />
    <exclusiveGateway id="gw_is_anomaly" name="Is Anomaly?" />
    <exclusiveGateway id="gw_merge" name="" />
    <startEvent id="ev_start" name="Admin Requests&#10;Anomaly Detection" />
    <task id="t_display" name="Display Anomaly Report&#10;with severity badges" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_anomaly">
    <bpmndi:BPMNPlane id="BPMNPlane_anomaly" bpmnElement="Collab_anomaly">
      <bpmndi:BPMNShape id="part_anomaly_di" bpmnElement="part_anomaly" isHorizontal="true">
        <dc:Bounds x="130" y="80" width="2200" height="660" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_db_di" bpmnElement="lane_db" isHorizontal="true">
        <dc:Bounds x="180" y="600" width="2150" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_ml_di" bpmnElement="lane_ml" isHorizontal="true">
        <dc:Bounds x="180" y="430" width="2150" height="170" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_api_di" bpmnElement="lane_api" isHorizontal="true">
        <dc:Bounds x="180" y="230" width="2150" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_client_di" bpmnElement="lane_client" isHorizontal="true">
        <dc:Bounds x="180" y="80" width="2150" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_validate_token_di" bpmnElement="t_validate_token">
        <dc:Bounds x="520" y="280" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_fetch_orders_di" bpmnElement="t_fetch_orders">
        <dc:Bounds x="740" y="280" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_select_orders_di" bpmnElement="t_select_orders">
        <dc:Bounds x="740" y="630" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_build_features_di" bpmnElement="t_build_features">
        <dc:Bounds x="960" y="280" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_load_model_di" bpmnElement="t_load_model">
        <dc:Bounds x="960" y="470" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_call_detect_di" bpmnElement="t_call_detect">
        <dc:Bounds x="1200" y="280" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_score_samples_di" bpmnElement="t_score_samples">
        <dc:Bounds x="1200" y="470" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_classify_severity_di" bpmnElement="t_classify_severity">
        <dc:Bounds x="1440" y="470" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_flag_order_di" bpmnElement="t_flag_order">
        <dc:Bounds x="1560" y="240" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_skip_di" bpmnElement="t_skip">
        <dc:Bounds x="1560" y="340" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_insert_anomaly_di" bpmnElement="t_insert_anomaly">
        <dc:Bounds x="1560" y="630" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_build_response_di" bpmnElement="t_build_response">
        <dc:Bounds x="1880" y="280" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ev_end_di" bpmnElement="ev_end">
        <dc:Bounds x="2192" y="137" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_request_di" bpmnElement="t_request">
        <dc:Bounds x="340" y="115" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_is_anomaly_di" bpmnElement="gw_is_anomaly" isMarkerVisible="true">
        <dc:Bounds x="1455" y="295" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1449" y="271" width="61" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_merge_di" bpmnElement="gw_merge" isMarkerVisible="true">
        <dc:Bounds x="1775" y="325" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ev_start_di" bpmnElement="ev_start">
        <dc:Bounds x="232" y="137" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="210" y="173" width="81" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_display_di" bpmnElement="t_display">
        <dc:Bounds x="1880" y="115" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf1_di" bpmnElement="sf1">
        <di:waypoint x="268" y="155" />
        <di:waypoint x="340" y="155" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf2_di" bpmnElement="sf2">
        <di:waypoint x="500" y="155" />
        <di:waypoint x="600" y="155" />
        <di:waypoint x="600" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf3_di" bpmnElement="sf3">
        <di:waypoint x="680" y="320" />
        <di:waypoint x="740" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf4_di" bpmnElement="sf4">
        <di:waypoint x="820" y="360" />
        <di:waypoint x="820" y="630" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf5_di" bpmnElement="sf5">
        <di:waypoint x="940" y="670" />
        <di:waypoint x="1050" y="670" />
        <di:waypoint x="1050" y="550" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf6_di" bpmnElement="sf6">
        <di:waypoint x="1050" y="470" />
        <di:waypoint x="1050" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf7_di" bpmnElement="sf7">
        <di:waypoint x="1140" y="320" />
        <di:waypoint x="1200" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf8_di" bpmnElement="sf8">
        <di:waypoint x="1280" y="360" />
        <di:waypoint x="1280" y="470" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf9_di" bpmnElement="sf9">
        <di:waypoint x="1380" y="510" />
        <di:waypoint x="1440" y="510" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf10_di" bpmnElement="sf10">
        <di:waypoint x="1530" y="470" />
        <di:waypoint x="1530" y="408" />
        <di:waypoint x="1480" y="408" />
        <di:waypoint x="1480" y="345" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf11_di" bpmnElement="sf11">
        <di:waypoint x="1505" y="320" />
        <di:waypoint x="1533" y="320" />
        <di:waypoint x="1533" y="280" />
        <di:waypoint x="1560" y="280" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1521" y="302" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf12_di" bpmnElement="sf12">
        <di:waypoint x="1505" y="320" />
        <di:waypoint x="1505" y="380" />
        <di:waypoint x="1560" y="380" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1487" y="341" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf13_di" bpmnElement="sf13">
        <di:waypoint x="1650" y="320" />
        <di:waypoint x="1650" y="630" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf14_di" bpmnElement="sf14">
        <di:waypoint x="1740" y="670" />
        <di:waypoint x="1800" y="670" />
        <di:waypoint x="1800" y="375" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf15_di" bpmnElement="sf15">
        <di:waypoint x="1700" y="400" />
        <di:waypoint x="1738" y="400" />
        <di:waypoint x="1738" y="350" />
        <di:waypoint x="1775" y="350" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf16_di" bpmnElement="sf16">
        <di:waypoint x="1825" y="350" />
        <di:waypoint x="1853" y="350" />
        <di:waypoint x="1853" y="320" />
        <di:waypoint x="1880" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf17_di" bpmnElement="sf17">
        <di:waypoint x="1980" y="280" />
        <di:waypoint x="1980" y="195" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf18_di" bpmnElement="sf18">
        <di:waypoint x="2080" y="155" />
        <di:waypoint x="2192" y="155" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
