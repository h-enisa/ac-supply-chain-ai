<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_anomaly" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <collaboration id="Collab_anomaly">
    <participant id="part_anomaly" name="Anomaly Detection Flow" processRef="proc_anomaly" />
  </collaboration>
  <process id="proc_anomaly" name="Anomaly Detection Process" isExecutable="false">
    <laneSet id="ls_anomaly">
      <lane id="lane_client" name="Client (Admin)">
        <flowNodeRef>ev_start</flowNodeRef>
        <flowNodeRef>t_request</flowNodeRef>
        <flowNodeRef>t_display</flowNodeRef>
        <flowNodeRef>ev_end</flowNodeRef>
      </lane>
      <lane id="lane_api" name="FastAPI — /ml/anomalies">
        <flowNodeRef>t_validate</flowNodeRef>
        <flowNodeRef>t_fetch_orders</flowNodeRef>
        <flowNodeRef>t_build_features</flowNodeRef>
        <flowNodeRef>t_run_model</flowNodeRef>
        <flowNodeRef>gw_anomaly</flowNodeRef>
        <flowNodeRef>t_save_anomaly</flowNodeRef>
        <flowNodeRef>t_skip</flowNodeRef>
        <flowNodeRef>gw_merge</flowNodeRef>
        <flowNodeRef>t_build_response</flowNodeRef>
      </lane>
      <lane id="lane_ml" name="ML Service — IsolationForest">
        <flowNodeRef>t_load_model</flowNodeRef>
        <flowNodeRef>t_score</flowNodeRef>
        <flowNodeRef>t_classify</flowNodeRef>
      </lane>
      <lane id="lane_db" name="Database">
        <flowNodeRef>t_select_orders</flowNodeRef>
        <flowNodeRef>t_insert_anomaly</flowNodeRef>
      </lane>
    </laneSet>

    <startEvent id="ev_start" name="Admin Requests&#10;Anomaly Detection" />
    <task id="t_request" name="GET /ml/anomalies&#10;?last_n=200" />
    <task id="t_validate" name="Validate Token&#10;role: admin only" />
    <task id="t_fetch_orders" name="Fetch Last N Orders&#10;with features" />
    <task id="t_select_orders" name="SELECT orders&#10;ORDER BY order_date DESC&#10;LIMIT last_n" />
    <task id="t_build_features" name="Build Feature Matrix&#10;distance, weather, customs,&#10;value, estimated_days" />
    <task id="t_load_model" name="Load anomaly_model.pkl&#10;IsolationForest" />
    <task id="t_run_model" name="Run detect_anomalies()&#10;pass features to model" />
    <task id="t_score" name="score_samples()&#10;compute anomaly scores" />
    <task id="t_classify" name="Classify Severity&#10;critical (score &lt; -0.3)&#10;warning (score &lt; -0.1)" />
    <exclusiveGateway id="gw_anomaly" name="Is Anomaly?" />
    <task id="t_save_anomaly" name="Flag Order as ANOMALY&#10;set anomaly_type, description" />
    <task id="t_skip" name="Mark as Normal&#10;skip" />
    <exclusiveGateway id="gw_merge" name="" />
    <task id="t_insert_anomaly" name="INSERT INTO anomalies&#10;score, severity, description" />
    <task id="t_build_response" name="Build Response&#10;{ anomalies[], total_flagged }" />
    <task id="t_display" name="Display Anomaly Report&#10;with severity badges" />
    <endEvent id="ev_end" name="Detection Complete" />

    <sequenceFlow id="sf1" sourceRef="ev_start" targetRef="t_request" />
    <sequenceFlow id="sf2" sourceRef="t_request" targetRef="t_validate" />
    <sequenceFlow id="sf3" sourceRef="t_validate" targetRef="t_fetch_orders" />
    <sequenceFlow id="sf4" sourceRef="t_fetch_orders" targetRef="t_select_orders" />
    <sequenceFlow id="sf5" sourceRef="t_select_orders" targetRef="t_build_features" />
    <sequenceFlow id="sf6" sourceRef="t_build_features" targetRef="t_load_model" />
    <sequenceFlow id="sf7" sourceRef="t_load_model" targetRef="t_run_model" />
    <sequenceFlow id="sf8" sourceRef="t_run_model" targetRef="t_score" />
    <sequenceFlow id="sf9" sourceRef="t_score" targetRef="t_classify" />
    <sequenceFlow id="sf10" sourceRef="t_classify" targetRef="gw_anomaly" />
    <sequenceFlow id="sf11" name="Yes" sourceRef="gw_anomaly" targetRef="t_save_anomaly" />
    <sequenceFlow id="sf12" name="No" sourceRef="gw_anomaly" targetRef="t_skip" />
    <sequenceFlow id="sf13" sourceRef="t_save_anomaly" targetRef="t_insert_anomaly" />
    <sequenceFlow id="sf14" sourceRef="t_insert_anomaly" targetRef="gw_merge" />
    <sequenceFlow id="sf15" sourceRef="t_skip" targetRef="gw_merge" />
    <sequenceFlow id="sf16" sourceRef="gw_merge" targetRef="t_build_response" />
    <sequenceFlow id="sf17" sourceRef="t_build_response" targetRef="t_display" />
    <sequenceFlow id="sf18" sourceRef="t_display" targetRef="ev_end" />
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_anomaly">
    <bpmndi:BPMNPlane id="BPMNPlane_anomaly" bpmnElement="Collab_anomaly">
      <bpmndi:BPMNShape id="part_anomaly_di" bpmnElement="part_anomaly" isHorizontal="true">
        <dc:Bounds x="130" y="80" width="2200" height="660" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_client_di" bpmnElement="lane_client" isHorizontal="true">
        <dc:Bounds x="180" y="80" width="2150" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_api_di" bpmnElement="lane_api" isHorizontal="true">
        <dc:Bounds x="180" y="230" width="2150" height="190" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_ml_di" bpmnElement="lane_ml" isHorizontal="true">
        <dc:Bounds x="180" y="420" width="2150" height="170" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_db_di" bpmnElement="lane_db" isHorizontal="true">
        <dc:Bounds x="180" y="590" width="2150" height="150" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="ev_start_di" bpmnElement="ev_start"><dc:Bounds x="212" y="137" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_request_di" bpmnElement="t_request"><dc:Bounds x="300" y="115" width="160" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_display_di" bpmnElement="t_display"><dc:Bounds x="1900" y="115" width="200" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ev_end_di" bpmnElement="ev_end"><dc:Bounds x="2162" y="137" width="36" height="36" /></bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="t_validate_di" bpmnElement="t_validate"><dc:Bounds x="520" y="265" width="160" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_fetch_orders_di" bpmnElement="t_fetch_orders"><dc:Bounds x="740" y="265" width="160" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_build_features_di" bpmnElement="t_build_features"><dc:Bounds x="960" y="265" width="180" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_run_model_di" bpmnElement="t_run_model"><dc:Bounds x="1200" y="265" width="160" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_anomaly_di" bpmnElement="gw_anomaly" isMarkerVisible="true"><dc:Bounds x="1435" y="280" width="50" height="50" /><bpmndi:BPMNLabel><dc:Bounds x="1422" y="337" width="76" height="14" /></bpmndi:BPMNLabel></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_save_anomaly_di" bpmnElement="t_save_anomaly"><dc:Bounds x="1540" y="230" width="180" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_skip_di" bpmnElement="t_skip"><dc:Bounds x="1540" y="330" width="140" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_merge_di" bpmnElement="gw_merge" isMarkerVisible="true"><dc:Bounds x="1755" y="295" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_build_response_di" bpmnElement="t_build_response"><dc:Bounds x="1860" y="265" width="180" height="80" /></bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="t_load_model_di" bpmnElement="t_load_model"><dc:Bounds x="960" y="455" width="180" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_score_di" bpmnElement="t_score"><dc:Bounds x="1200" y="455" width="160" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_classify_di" bpmnElement="t_classify"><dc:Bounds x="1420" y="455" width="180" height="80" /></bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="t_select_orders_di" bpmnElement="t_select_orders"><dc:Bounds x="740" y="625" width="180" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_insert_anomaly_di" bpmnElement="t_insert_anomaly"><dc:Bounds x="1540" y="625" width="180" height="80" /></bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="sf1_di" bpmnElement="sf1"><di:waypoint x="248" y="155" /><di:waypoint x="300" y="155" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf2_di" bpmnElement="sf2"><di:waypoint x="380" y="155" /><di:waypoint x="600" y="155" /><di:waypoint x="600" y="265" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf3_di" bpmnElement="sf3"><di:waypoint x="680" y="305" /><di:waypoint x="740" y="305" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf4_di" bpmnElement="sf4"><di:waypoint x="820" y="345" /><di:waypoint x="820" y="625" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf5_di" bpmnElement="sf5"><di:waypoint x="920" y="665" /><di:waypoint x="1050" y="665" /><di:waypoint x="1050" y="535" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf6_di" bpmnElement="sf6"><di:waypoint x="1050" y="455" /><di:waypoint x="1050" y="345" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf7_di" bpmnElement="sf7"><di:waypoint x="1140" y="305" /><di:waypoint x="1200" y="305" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf8_di" bpmnElement="sf8"><di:waypoint x="1280" y="345" /><di:waypoint x="1280" y="455" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf9_di" bpmnElement="sf9"><di:waypoint x="1360" y="495" /><di:waypoint x="1420" y="495" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf10_di" bpmnElement="sf10"><di:waypoint x="1510" y="495" /><di:waypoint x="1460" y="495" /><di:waypoint x="1460" y="330" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf11_di" bpmnElement="sf11"><di:waypoint x="1460" y="280" /><di:waypoint x="1460" y="270" /><di:waypoint x="1540" y="270" /><bpmndi:BPMNLabel><dc:Bounds x="1470" y="262" width="19" height="14" /></bpmndi:BPMNLabel></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf12_di" bpmnElement="sf12"><di:waypoint x="1485" y="305" /><di:waypoint x="1540" y="370" /><bpmndi:BPMNLabel><dc:Bounds x="1496" y="330" width="15" height="14" /></bpmndi:BPMNLabel></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf13_di" bpmnElement="sf13"><di:waypoint x="1630" y="310" /><di:waypoint x="1630" y="625" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf14_di" bpmnElement="sf14"><di:waypoint x="1720" y="665" /><di:waypoint x="1780" y="665" /><di:waypoint x="1780" y="345" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf15_di" bpmnElement="sf15"><di:waypoint x="1680" y="370" /><di:waypoint x="1780" y="320" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf16_di" bpmnElement="sf16"><di:waypoint x="1805" y="320" /><di:waypoint x="1860" y="305" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf17_di" bpmnElement="sf17"><di:waypoint x="1950" y="265" /><di:waypoint x="1950" y="195" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf18_di" bpmnElement="sf18"><di:waypoint x="2100" y="155" /><di:waypoint x="2162" y="155" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
