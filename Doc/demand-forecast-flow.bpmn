<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_forecast" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <collaboration id="Collab_forecast">
    <participant id="part_forecast" name="Demand Forecast Flow" processRef="proc_forecast" />
  </collaboration>
  <process id="proc_forecast" isExecutable="false">
    <laneSet id="ls_forecast">
      <lane id="lane_client" name="Client">
        <flowNodeRef>t_display</flowNodeRef>
        <flowNodeRef>ev_end</flowNodeRef>
        <flowNodeRef>t_request</flowNodeRef>
        <flowNodeRef>ev_start</flowNodeRef>
      </lane>
      <lane id="lane_api" name="FastAPI — POST /ml/forecast">
        <flowNodeRef>t_validate</flowNodeRef>
        <flowNodeRef>t_call_service</flowNodeRef>
        <flowNodeRef>t_build_response</flowNodeRef>
        <flowNodeRef>t_load_model</flowNodeRef>
        <flowNodeRef>gw_loaded</flowNodeRef>
      </lane>
      <lane id="lane_ml" name="ML Service — ARIMA(2,1,2)">
        <flowNodeRef>t_fetch_series</flowNodeRef>
        <flowNodeRef>t_preprocess</flowNodeRef>
        <flowNodeRef>t_arima_forecast</flowNodeRef>
        <flowNodeRef>t_conf_interval</flowNodeRef>
        <flowNodeRef>t_metrics</flowNodeRef>
      </lane>
      <lane id="lane_db" name="Database">
        <flowNodeRef>t_read_demand</flowNodeRef>
      </lane>
    </laneSet>
    <task id="t_validate" name="Validate Request&#10;ForecastRequest schema" />
    <task id="t_call_service" name="Call predict_demand()&#10;MLService singleton">
      <incoming>Flow_1tlx4wk</incoming>
    </task>
    <task id="t_fetch_series" name="Fetch demand series&#10;by category" />
    <task id="t_read_demand" name="SELECT FROM demand_records&#10;GROUP BY date" />
    <task id="t_preprocess" name="Preprocess time series&#10;resample, fill gaps" />
    <task id="t_arima_forecast" name="ARIMAResults.get_forecast()&#10;steps = horizon_days" />
    <task id="t_conf_interval" name="Extract confidence intervals&#10;alpha = 0.15 (85%)" />
    <task id="t_metrics" name="Return RMSE, MAE, R²&#10;from arima_metrics.pkl" />
    <task id="t_display" name="Display Forecast Chart&#10;with confidence bands" />
    <endEvent id="ev_end" name="Forecast Complete" />
    <sequenceFlow id="sf1" sourceRef="ev_start" targetRef="t_request" />
    <sequenceFlow id="sf2" sourceRef="t_request" targetRef="t_validate" />
    <sequenceFlow id="sf3" sourceRef="t_validate" targetRef="gw_loaded" />
    <sequenceFlow id="sf6" name="Yes" sourceRef="gw_loaded" targetRef="t_load_model" />
    <sequenceFlow id="sf7" sourceRef="t_call_service" targetRef="t_fetch_series" />
    <sequenceFlow id="sf8" sourceRef="t_fetch_series" targetRef="t_read_demand" />
    <sequenceFlow id="sf9" sourceRef="t_read_demand" targetRef="t_preprocess" />
    <sequenceFlow id="sf10" sourceRef="t_preprocess" targetRef="t_arima_forecast" />
    <sequenceFlow id="sf11" sourceRef="t_arima_forecast" targetRef="t_conf_interval" />
    <sequenceFlow id="sf12" sourceRef="t_conf_interval" targetRef="t_metrics" />
    <sequenceFlow id="sf13" sourceRef="t_metrics" targetRef="t_build_response" />
    <sequenceFlow id="sf14" sourceRef="t_build_response" targetRef="t_display" />
    <sequenceFlow id="sf15" sourceRef="t_display" targetRef="ev_end" />
    <task id="t_request" name="POST /ml/forecast&#10;{ category, horizon_days }" />
    <startEvent id="ev_start" name="Client Requests Forecast" />
    <sequenceFlow id="Flow_1tlx4wk" sourceRef="t_load_model" targetRef="t_call_service" />
    <task id="t_build_response" name="Build ForecastResponse&#10;{ forecast[], rmse, mae, r2,&#10;model_name, horizon_days }" />
    <task id="t_load_model" name="Load arima_model.pkl&#10;arima_metrics.pkl&#10;demand_series.pkl">
      <incoming>sf6</incoming>
      <outgoing>Flow_1tlx4wk</outgoing>
    </task>
    <exclusiveGateway id="gw_loaded" name="ARIMA model&#10;loaded?" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_forecast">
    <bpmndi:BPMNPlane id="BPMNPlane_forecast" bpmnElement="Collab_forecast">
      <bpmndi:BPMNShape id="part_forecast_di" bpmnElement="part_forecast" isHorizontal="true">
        <dc:Bounds x="130" y="80" width="2100" height="640" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_db_di" bpmnElement="lane_db" isHorizontal="true">
        <dc:Bounds x="180" y="570" width="2050" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_ml_di" bpmnElement="lane_ml" isHorizontal="true">
        <dc:Bounds x="180" y="400" width="2050" height="170" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_api_di" bpmnElement="lane_api" isHorizontal="true">
        <dc:Bounds x="180" y="230" width="2050" height="170" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_client_di" bpmnElement="lane_client" isHorizontal="true">
        <dc:Bounds x="180" y="80" width="2050" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_validate_di" bpmnElement="t_validate">
        <dc:Bounds x="540" y="270" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_call_service_di" bpmnElement="t_call_service">
        <dc:Bounds x="1100" y="270" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_fetch_series_di" bpmnElement="t_fetch_series">
        <dc:Bounds x="1100" y="440" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_read_demand_di" bpmnElement="t_read_demand">
        <dc:Bounds x="1100" y="610" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_preprocess_di" bpmnElement="t_preprocess">
        <dc:Bounds x="1320" y="440" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_arima_forecast_di" bpmnElement="t_arima_forecast">
        <dc:Bounds x="1540" y="440" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_conf_interval_di" bpmnElement="t_conf_interval">
        <dc:Bounds x="1780" y="440" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_metrics_di" bpmnElement="t_metrics">
        <dc:Bounds x="2000" y="440" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_display_di" bpmnElement="t_display">
        <dc:Bounds x="1800" y="115" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ev_end_di" bpmnElement="ev_end">
        <dc:Bounds x="2062" y="137" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_request_di" bpmnElement="t_request">
        <dc:Bounds x="330" y="115" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ev_start_di" bpmnElement="ev_start">
        <dc:Bounds x="232" y="137" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="211" y="173" width="78" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_build_response_di" bpmnElement="t_build_response">
        <dc:Bounds x="1770" y="280" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_load_model_di" bpmnElement="t_load_model">
        <dc:Bounds x="880" y="270" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_loaded_di" bpmnElement="gw_loaded" isMarkerVisible="true">
        <dc:Bounds x="760" y="285" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="752" y="342" width="67" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf1_di" bpmnElement="sf1">
        <di:waypoint x="268" y="155" />
        <di:waypoint x="330" y="155" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf2_di" bpmnElement="sf2">
        <di:waypoint x="510" y="155" />
        <di:waypoint x="620" y="155" />
        <di:waypoint x="620" y="270" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf3_di" bpmnElement="sf3">
        <di:waypoint x="700" y="310" />
        <di:waypoint x="760" y="310" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf6_di" bpmnElement="sf6">
        <di:waypoint x="810" y="310" />
        <di:waypoint x="880" y="310" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="851" y="302" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf7_di" bpmnElement="sf7">
        <di:waypoint x="1190" y="350" />
        <di:waypoint x="1190" y="440" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf8_di" bpmnElement="sf8">
        <di:waypoint x="1190" y="520" />
        <di:waypoint x="1190" y="610" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf9_di" bpmnElement="sf9">
        <di:waypoint x="1300" y="650" />
        <di:waypoint x="1400" y="650" />
        <di:waypoint x="1400" y="520" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf10_di" bpmnElement="sf10">
        <di:waypoint x="1480" y="480" />
        <di:waypoint x="1540" y="480" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf11_di" bpmnElement="sf11">
        <di:waypoint x="1720" y="480" />
        <di:waypoint x="1780" y="480" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf12_di" bpmnElement="sf12">
        <di:waypoint x="1960" y="480" />
        <di:waypoint x="2000" y="480" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf13_di" bpmnElement="sf13">
        <di:waypoint x="2080" y="440" />
        <di:waypoint x="2080" y="380" />
        <di:waypoint x="1870" y="380" />
        <di:waypoint x="1870" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf14_di" bpmnElement="sf14">
        <di:waypoint x="1860" y="280" />
        <di:waypoint x="1860" y="195" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf15_di" bpmnElement="sf15">
        <di:waypoint x="2000" y="155" />
        <di:waypoint x="2062" y="155" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1tlx4wk_di" bpmnElement="Flow_1tlx4wk">
        <di:waypoint x="1060" y="310" />
        <di:waypoint x="1100" y="310" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
