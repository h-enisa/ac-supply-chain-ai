<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_login" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <collaboration id="Collab_login">
    <participant id="part_login" name="Login Flow" processRef="proc_login" />
  </collaboration>
  <process id="proc_login" isExecutable="false">
    <laneSet id="ls_login">
      <lane id="lane_client" name="Client (Frontend)">
        <flowNodeRef>t_show_error</flowNodeRef>
        <flowNodeRef>ev_end</flowNodeRef>
        <flowNodeRef>t_submit_json</flowNodeRef>
        <flowNodeRef>t_store_token</flowNodeRef>
        <flowNodeRef>t_choose</flowNodeRef>
        <flowNodeRef>ev_start</flowNodeRef>
        <flowNodeRef>t_enter</flowNodeRef>
        <flowNodeRef>t_submit_form</flowNodeRef>
      </lane>
      <lane id="lane_api" name="Backend (FastAPI) — POST /auth/token or /auth/login/form">
        <flowNodeRef>t_lookup</flowNodeRef>
        <flowNodeRef>t_bcrypt</flowNodeRef>
        <flowNodeRef>gw_valid</flowNodeRef>
        <flowNodeRef>t_check_active</flowNodeRef>
        <flowNodeRef>gw_active</flowNodeRef>
        <flowNodeRef>t_update_login</flowNodeRef>
        <flowNodeRef>t_jwt</flowNodeRef>
      </lane>
      <lane id="lane_db" name="Database (PostgreSQL)">
        <flowNodeRef>t_select_user</flowNodeRef>
        <flowNodeRef>t_update_db</flowNodeRef>
      </lane>
    </laneSet>
    <task id="t_lookup" name="Lookup User&#10;SELECT FROM users&#10;WHERE username = ?" />
    <task id="t_select_user" name="Return user record" />
    <task id="t_bcrypt" name="verify_password()&#10;bcrypt check" />
    <exclusiveGateway id="gw_valid" name="Valid?" />
    <task id="t_show_error" name="Return 401&#10;Incorrect credentials" />
    <task id="t_check_active" name="Check is_active" />
    <exclusiveGateway id="gw_active" name="Active?" />
    <task id="t_update_login" name="UPDATE last_login&#10;= datetime.utcnow()" />
    <task id="t_update_db" name="db.commit()" />
    <endEvent id="ev_end" name="Authenticated" />
    <sequenceFlow id="sf1" sourceRef="ev_start" targetRef="t_enter" />
    <sequenceFlow id="sf2" sourceRef="t_enter" targetRef="t_choose" />
    <sequenceFlow id="sf3" name="JSON" sourceRef="t_choose" targetRef="t_submit_json" />
    <sequenceFlow id="sf4" name="Form" sourceRef="t_choose" targetRef="t_submit_form" />
    <sequenceFlow id="sf5" sourceRef="t_submit_json" targetRef="t_lookup" />
    <sequenceFlow id="sf6" sourceRef="t_submit_form" targetRef="t_lookup" />
    <sequenceFlow id="sf7" sourceRef="t_lookup" targetRef="t_select_user" />
    <sequenceFlow id="sf8" sourceRef="t_select_user" targetRef="t_bcrypt" />
    <sequenceFlow id="sf9" sourceRef="t_bcrypt" targetRef="gw_valid" />
    <sequenceFlow id="sf10" name="Invalid" sourceRef="gw_valid" targetRef="t_show_error" />
    <sequenceFlow id="sf11" sourceRef="t_show_error" targetRef="t_enter" />
    <sequenceFlow id="sf12" name="Valid" sourceRef="gw_valid" targetRef="t_check_active" />
    <sequenceFlow id="sf13" name="Disabled" sourceRef="gw_active" targetRef="t_show_error" />
    <sequenceFlow id="sf14" name="Active" sourceRef="gw_active" targetRef="t_jwt" />
    <sequenceFlow id="sf15" sourceRef="t_check_active" targetRef="gw_active" />
    <sequenceFlow id="sf16" sourceRef="t_jwt" targetRef="t_update_login" />
    <sequenceFlow id="sf17" sourceRef="t_update_login" targetRef="t_update_db" />
    <sequenceFlow id="sf18" sourceRef="t_update_db" targetRef="t_jwt" />
    <sequenceFlow id="sf19" sourceRef="t_store_token" targetRef="ev_end" />
    <task id="t_submit_json" name="POST /auth/token&#10;{ username, password }" />
    <task id="t_jwt" name="create_access_token()&#10;JWT { sub: username, role }">
      <incoming>sf18</incoming>
      <outgoing>Flow_0p3mrl0</outgoing>
    </task>
    <sequenceFlow id="Flow_0p3mrl0" sourceRef="t_jwt" targetRef="t_store_token" />
    <task id="t_store_token" name="Return TokenResponse&#10;{ access_token, user }&#10;Store in memory">
      <incoming>Flow_0p3mrl0</incoming>
    </task>
    <exclusiveGateway id="t_choose" name="Login Method?" />
    <startEvent id="ev_start" name="Open Login Page" />
    <task id="t_enter" name="Enter Username&#10;and Password" />
    <task id="t_submit_form" name="POST /auth/login/form&#10;OAuth2PasswordRequestForm" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_login">
    <bpmndi:BPMNPlane id="BPMNPlane_login" bpmnElement="Collab_login">
      <bpmndi:BPMNShape id="part_login_di" bpmnElement="part_login" isHorizontal="true">
        <dc:Bounds x="130" y="80" width="2050" height="560" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_db_di" bpmnElement="lane_db" isHorizontal="true">
        <dc:Bounds x="180" y="460" width="2000" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_api_di" bpmnElement="lane_api" isHorizontal="true">
        <dc:Bounds x="180" y="270" width="2000" height="190" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_client_di" bpmnElement="lane_client" isHorizontal="true">
        <dc:Bounds x="180" y="80" width="2000" height="190" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_lookup_di" bpmnElement="t_lookup">
        <dc:Bounds x="840" y="315" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_select_user_di" bpmnElement="t_select_user">
        <dc:Bounds x="840" y="505" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_bcrypt_di" bpmnElement="t_bcrypt">
        <dc:Bounds x="1080" y="315" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_valid_di" bpmnElement="gw_valid" isMarkerVisible="true">
        <dc:Bounds x="1295" y="330" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1298" y="387" width="44" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_show_error_di" bpmnElement="t_show_error">
        <dc:Bounds x="1020" y="135" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_check_active_di" bpmnElement="t_check_active">
        <dc:Bounds x="1400" y="315" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_active_di" bpmnElement="gw_active" isMarkerVisible="true">
