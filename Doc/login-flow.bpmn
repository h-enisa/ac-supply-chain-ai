        <bpmndi:BPMNLabel>
          <dc:Bounds x="1196" y="243" width="34" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf11_di" bpmnElement="sf11">
        <di:waypoint x="1020" y="175" />
        <di:waypoint x="460" y="175" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf12_di" bpmnElement="sf12">
        <di:waypoint x="1345" y="355" />
