        <di:waypoint x="1088" y="300" />
        <di:waypoint x="1120" y="300" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1068" y="318" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf10_di" bpmnElement="sf10">
        <di:waypoint x="1030" y="360" />
        <di:waypoint x="1030" y="400" />
        <di:waypoint x="1120" y="400" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1047" y="378" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf11_di" bpmnElement="sf11">
        <di:waypoint x="1300" y="300" />
        <di:waypoint x="1343" y="300" />
        <di:waypoint x="1343" y="320" />
        <di:waypoint x="1365" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf12_di" bpmnElement="sf12">
        <di:waypoint x="1300" y="400" />
        <di:waypoint x="1390" y="400" />
        <di:waypoint x="1390" y="345" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf13_di" bpmnElement="sf13">
        <di:waypoint x="1415" y="320" />
        <di:waypoint x="1443" y="320" />
        <di:waypoint x="1443" y="335" />
        <di:waypoint x="1470" y="335" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf14_di" bpmnElement="sf14">
        <di:waypoint x="1650" y="335" />
        <di:waypoint x="1760" y="335" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf15_di" bpmnElement="sf15">
        <di:waypoint x="1850" y="375" />
        <di:waypoint x="1850" y="498" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf16_di" bpmnElement="sf16">
        <di:waypoint x="1850" y="498" />
        <di:waypoint x="1850" y="460" />
        <di:waypoint x="1730" y="460" />
        <di:waypoint x="1730" y="208" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf17_di" bpmnElement="sf17">
        <di:waypoint x="1940" y="541" />
        <di:waypoint x="1951" y="541" />
        <di:waypoint x="1951" y="538" />
        <di:waypoint x="1962" y="538" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf18_di" bpmnElement="sf18">
        <di:waypoint x="1820" y="168" />
        <di:waypoint x="1880" y="168" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf19_di" bpmnElement="sf19">
        <di:waypoint x="2060" y="168" />
