<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_register" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <collaboration id="Collab_register">
    <participant id="part_register" name="Register Flow" processRef="proc_register" />
  </collaboration>
  <process id="proc_register" isExecutable="false">
    <laneSet id="ls_register">
      <lane id="lane_client" name="Client (Frontend)">
        <flowNodeRef>t_fill_form</flowNodeRef>
        <flowNodeRef>t_show_error</flowNodeRef>
        <flowNodeRef>t_show_success</flowNodeRef>
        <flowNodeRef>t_redirect</flowNodeRef>
        <flowNodeRef>ev_end</flowNodeRef>
        <flowNodeRef>ev_start</flowNodeRef>
        <flowNodeRef>t_submit</flowNodeRef>
      </lane>
      <lane id="lane_api" name="Backend (FastAPI) — POST /auth/register">
        <flowNodeRef>t_validate</flowNodeRef>
        <flowNodeRef>gw_exists</flowNodeRef>
        <flowNodeRef>t_role_admin</flowNodeRef>
        <flowNodeRef>t_role_payload</flowNodeRef>
        <flowNodeRef>t_hash</flowNodeRef>
        <flowNodeRef>t_create_user</flowNodeRef>
        <flowNodeRef>gw_first</flowNodeRef>
        <flowNodeRef>gw_merge_role</flowNodeRef>
      </lane>
      <lane id="lane_db" name="Database (PostgreSQL)">
        <flowNodeRef>t_check_user</flowNodeRef>
        <flowNodeRef>ev_end_db</flowNodeRef>
        <flowNodeRef>t_insert_user</flowNodeRef>
      </lane>
    </laneSet>
    <task id="t_fill_form" name="Fill Registration Form&#10;username, email, password, role">
      <incoming>Flow_1c3ereb</incoming>
    </task>
    <task id="t_validate" name="Validate Input&#10;Pydantic — UserRegister schema" />
    <task id="t_check_user" name="SELECT FROM users&#10;WHERE username = ? OR email = ?" />
    <exclusiveGateway id="gw_exists" name="Already exists?" />
    <task id="t_show_error" name="Return 400&#10;Username / Email already taken" />
    <task id="t_role_admin" name="Assign role = admin&#10;(first user auto-admin)" />
    <task id="t_role_payload" name="Assign role from payload&#10;admin / viewer" />
    <task id="t_hash" name="bcrypt.hash(password[:72])&#10;Generate hashed_password" />
    <task id="t_show_success" name="Return 201 Created&#10;UserOut response" />
    <task id="t_redirect" name="Redirect to Login / Dashboard" />
    <endEvent id="ev_end" name="Registered" />
    <endEvent id="ev_end_db" name="Saved" />
    <sequenceFlow id="sf1" sourceRef="ev_start" targetRef="t_fill_form" />
    <sequenceFlow id="sf2" sourceRef="t_fill_form" targetRef="t_submit" />
    <sequenceFlow id="sf3" sourceRef="t_submit" targetRef="t_validate" />
    <sequenceFlow id="sf4" sourceRef="t_validate" targetRef="t_check_user" />
    <sequenceFlow id="sf5" sourceRef="t_check_user" targetRef="gw_exists" />
    <sequenceFlow id="sf6" name="Yes" sourceRef="gw_exists" targetRef="t_show_error" />
    <sequenceFlow id="sf7" sourceRef="t_show_error" targetRef="t_submit" />
    <sequenceFlow id="sf8" name="No" sourceRef="gw_exists" targetRef="gw_first" />
    <sequenceFlow id="sf9" name="Yes" sourceRef="gw_first" targetRef="t_role_admin" />
    <sequenceFlow id="sf10" name="No" sourceRef="gw_first" targetRef="t_role_payload" />
    <sequenceFlow id="sf11" sourceRef="t_role_admin" targetRef="gw_merge_role" />
    <sequenceFlow id="sf12" sourceRef="t_role_payload" targetRef="gw_merge_role" />
    <sequenceFlow id="sf13" sourceRef="gw_merge_role" targetRef="t_hash" />
    <sequenceFlow id="sf14" sourceRef="t_hash" targetRef="t_create_user" />
    <sequenceFlow id="sf15" sourceRef="t_create_user" targetRef="t_insert_user" />
    <sequenceFlow id="sf16" sourceRef="t_insert_user" targetRef="t_show_success" />
    <sequenceFlow id="sf17" sourceRef="t_insert_user" targetRef="ev_end_db" />
    <sequenceFlow id="sf18" sourceRef="t_show_success" targetRef="t_redirect" />
    <sequenceFlow id="sf19" sourceRef="t_redirect" targetRef="ev_end" />
    <sequenceFlow id="Flow_1c3ereb" sourceRef="t_submit" targetRef="t_fill_form" />
    <task id="t_create_user" name="Create User object&#10;username, email, full_name,&#10;hashed_password, role" />
    <task id="t_insert_user" name="INSERT INTO users&#10;db.commit() / db.refresh()" />
    <exclusiveGateway id="gw_first" name="First user&#10;in DB?" />
    <exclusiveGateway id="gw_merge_role" name="" />
    <startEvent id="ev_start" name="Open Register Page" />
    <task id="t_submit" name="Submit Form">
      <incoming>sf7</incoming>
      <outgoing>Flow_1c3ereb</outgoing>
    </task>
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_register">
    <bpmndi:BPMNPlane id="BPMNPlane_register" bpmnElement="Collab_register">
      <bpmndi:BPMNShape id="part_register_di" bpmnElement="part_register" isHorizontal="true">
        <dc:Bounds x="130" y="80" width="2100" height="560" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_db_di" bpmnElement="lane_db" isHorizontal="true">
        <dc:Bounds x="180" y="460" width="2050" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_api_di" bpmnElement="lane_api" isHorizontal="true">
        <dc:Bounds x="180" y="250" width="2050" height="210" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_client_di" bpmnElement="lane_client" isHorizontal="true">
        <dc:Bounds x="180" y="80" width="2050" height="170" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_fill_form_di" bpmnElement="t_fill_form">
        <dc:Bounds x="300" y="128" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_validate_di" bpmnElement="t_validate">
        <dc:Bounds x="540" y="295" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_exists_di" bpmnElement="gw_exists" isMarkerVisible="true">
        <dc:Bounds x="855" y="310" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="836" y="367" width="88" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_show_error_di" bpmnElement="t_show_error">
        <dc:Bounds x="840" y="128" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_role_admin_di" bpmnElement="t_role_admin">
        <dc:Bounds x="1120" y="260" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_role_payload_di" bpmnElement="t_role_payload">
        <dc:Bounds x="1120" y="360" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_hash_di" bpmnElement="t_hash">
        <dc:Bounds x="1470" y="295" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_show_success_di" bpmnElement="t_show_success">
        <dc:Bounds x="1640" y="128" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_redirect_di" bpmnElement="t_redirect">
        <dc:Bounds x="1880" y="128" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ev_end_di" bpmnElement="ev_end">
        <dc:Bounds x="2122" y="150" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2108" y="193" width="64" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ev_end_db_di" bpmnElement="ev_end_db">
        <dc:Bounds x="1962" y="520" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1958" y="563" width="44" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_create_user_di" bpmnElement="t_create_user">
        <dc:Bounds x="1760" y="295" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_insert_user_di" bpmnElement="t_insert_user">
        <dc:Bounds x="1760" y="498" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_first_di" bpmnElement="gw_first" isMarkerVisible="true">
        <dc:Bounds x="1005" y="310" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1006" y="272.5" width="47" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_merge_role_di" bpmnElement="gw_merge_role" isMarkerVisible="true">
        <dc:Bounds x="1365" y="295" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ev_start_di" bpmnElement="ev_start">
        <dc:Bounds x="222" y="150" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="204" y="193" width="73" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_submit_di" bpmnElement="t_submit">
        <dc:Bounds x="540" y="128" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf1_di" bpmnElement="sf1">
        <di:waypoint x="258" y="168" />
        <di:waypoint x="300" y="168" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf2_di" bpmnElement="sf2">
        <di:waypoint x="480" y="168" />
        <di:waypoint x="540" y="168" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf3_di" bpmnElement="sf3">
        <di:waypoint x="620" y="208" />
        <di:waypoint x="620" y="295" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf6_di" bpmnElement="sf6">
        <di:waypoint x="880" y="310" />
        <di:waypoint x="880" y="208" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="887" y="258" width="19" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf7_di" bpmnElement="sf7">
        <di:waypoint x="840" y="168" />
        <di:waypoint x="680" y="168" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf8_di" bpmnElement="sf8">
        <di:waypoint x="905" y="335" />
        <di:waypoint x="1005" y="335" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="945" y="317" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf9_di" bpmnElement="sf9">
        <di:waypoint x="1055" y="335" />
