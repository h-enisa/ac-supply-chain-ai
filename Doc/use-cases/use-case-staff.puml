@startuml Staff Use Cases

!define ACTOR_COLOR #4A7BA7
!define SYSTEM_COLOR #E6F0FF
!define USECASE_COLOR #D0E8F2

skinparam actor {
    BackgroundColor #4A7BA7
    BorderColor #003366
    FontColor #FFF
}
skinparam rectangle {
    BackgroundColor #E6F0FF
    BorderColor #003366
    FontColor #000
}
skinparam usecase {
    BackgroundColor #D0E8F2
    BorderColor #0066CC
    FontColor #000
}
skinparam note {
    BackgroundColor #F5F5F5
    BorderColor #666666
    FontColor #333333
}

actor "Staff" as STAFF

rectangle "AC Supply Chain System" {
    usecase "Login / Register" as UC_LOGIN
    usecase "View Orders" as UC_ORDERS
    usecase "Create Order" as UC_CREATE
    usecase "View Inventory" as UC_INV
    usecase "View KPIs" as UC_KPIS
    usecase "Forecast Demand" as UC_FORECAST
    usecase "Predict Delay Risk" as UC_DELAY
    usecase "Chat with Agent" as UC_CHAT
    usecase "Manage Suppliers" as UC_SUP
    usecase "Reset Password" as UC_RESET
}

STAFF --> UC_LOGIN
STAFF --> UC_ORDERS
STAFF --> UC_CREATE
STAFF --> UC_INV
STAFF --> UC_KPIS
STAFF --> UC_CHAT
STAFF --> UC_SUP

UC_CREATE ..|> UC_DELAY : includes
UC_CREATE ..|> UC_FORECAST : includes
UC_LOGIN ..|> UC_RESET : requires

note right of UC_DELAY
  RandomForest
  predict_delay()
  → LOW / MEDIUM / HIGH
end note

note right of UC_FORECAST
  ARIMA(2,1,2)
  predict_demand()
  → forecast + conf. interval
end note

@enduml
